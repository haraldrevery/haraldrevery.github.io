# node_modules/ is intentionally COMMITTED (27 MB, pure JS, works on both
# Linux and Windows) so the site builds without `npm install` even if the
# npm registry is down. Only this secondary tool's copy stays ignored:
revery_notebook/build_tools/node_modules/

# Stale duplicate CSS backups
css_bkup/

# OS / editor cruft
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*~
.idea/
.vscode/

# Logs
npm-debug.log*
*.log

# Python bytecode (page_builder/)
__pycache__/
*.pyc

# Tailwind standalone binaries — EXCLUDED because each exceeds GitHub's 100 MB
# per-file limit (git push would be rejected). They are local-only build tools;
# keep them in your zip backups. See update_to_git_guide.md.
tailwindcss-linux-x64
tw.exe

# Standalone Eleventy build binaries (~95 MB each, brush against GitHub's
# 100 MB limit and would bloat git history on every recompile). Local-only
# build tools; keep them in your zip backups. Recompile any time with
# eleventy_binary/compile.sh — see eleventy_binary/README.md.
eleventy-linux-x64
eleventy-win-x64.exe

# NOTE: intentionally NOT ignored (must stay committed):
#   - Built output: main.css, main_max.css, prose.css, prose_max.css, notebook_pages/
#     (GitHub Pages serves this folder as-is; there is no CI build step)
